{
  // REFACTOR (2026-07): Previously extended a tsconfig buried inside the
  // deprecated @grafana/toolkit package. The options are now declared
  // explicitly (matching the @grafana/create-plugin defaults) so the project
  // no longer depends on the toolkit at all.
  "compilerOptions": {
    "target": "ES2018",
    "module": "esnext",
    // FIX (2026-07): "node" (node10) resolution is deprecated and becomes an
    // error in TypeScript 7. "bundler" matches how the code is actually
    // consumed (webpack) and understands package.json "exports" maps.
    "moduleResolution": "bundler",
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "es2018"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "importHelpers": true,
    // FIX (2026-07): removed deprecated "baseUrl" (TS 7 deprecation). All
    // source imports are relative, so nothing depended on it.
    // REFACTOR (2026-07-02): removed "rootDir": "./src" so the tests/ tree
    // (unit + e2e) is type-checked alongside the sources.
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
