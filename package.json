{
  "name": "esnet-chord-panel",
  "version": "2.0.0",
  "description": "ESnet Chord Diagram Plugin for Grafana 10.4+",
  "private": true,
  "scripts": {
    "build": "webpack -c ./webpack.config.js --env production",
    "dev": "webpack -w -c ./webpack.config.js --env development",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx ./src ./tests",
    "lint:fix": "npm run lint -- --fix",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "ESnet - Lawrence Berkeley National Laboratory",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@emotion/css": "^11.11.2",
    "@grafana/data": "^11.6.0",
    "@grafana/runtime": "^11.6.0",
    "@grafana/ui": "^11.6.0",
    "d3": "^7.9.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tslib": "^2.6.3"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^7.0.0",
    "@grafana/plugin-e2e": "^3.9.1",
    "@playwright/test": "^1.61.1",
    "@swc/core": "^1.5.7",
    "@swc/helpers": "^0.5.11",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.57.0",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.2",
    "swc-loader": "^0.2.6",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
